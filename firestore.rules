rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users can read and write to their own profile.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Any authenticated user can read study groups and projects.
    match /studyGroups/{groupId} {
      allow read: if request.auth != null;
      // Only members can update a group
      allow write: if request.auth != null && request.auth.uid in resource.data.memberIds;
    }

    match /projects/{projectId} {
      allow read: if request.auth != null;
      // Only the owner can write to a project
      allow write: if request.auth != null && request.auth.uid == request.resource.data.ownerId;
    }
  }
}
    