
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getIncomingData() {
      return request.resource.data;
    }
    
    function getExistingData() {
      return resource.data;
    }
    
    // --- User Profile Rules (/users/{userId}) ---
    match /users/{userId} {
      allow get: if isSignedIn();
      allow create: if isOwner(userId) && getIncomingData().userId == userId;
      allow update: if isOwner(userId) 
                      && getIncomingData().userId == getExistingData().userId
                      && getIncomingData().username == getExistingData().username;
      allow delete: if isOwner(userId);
      allow list: if false;
    }

    // --- Username Uniqueness Rules (/usernames/{username}) ---
    match /usernames/{username} {
      allow get: if true;
      allow create: if isSignedIn() && getIncomingData().userId == request.auth.uid;
      allow update, delete: if false;
    }
    
    // --- Counter Rules (/counters/{counterId}) ---
    match /counters/{counterId} {
      allow read, write: if isSignedIn();
    }

    // --- Learning Group Rules (/learning_groups/{learningGroupId}) ---
    match /learning_groups/{learningGroupId} {
      
      // --- Helper Functions for Groups ---
      function isGroupMember() {
        return request.auth.uid in getExistingData().members;
      }
      
      function didJoin() {
        let newMembers = getIncomingData().members;
        let oldMembers = getExistingData().members;
        // The new member's UID must be in the new list
        return request.auth.uid in newMembers &&
               // The new member must NOT have been in the old list
               !(request.auth.uid in oldMembers) &&
               // The new list size must be one greater than the old one
               newMembers.size() == oldMembers.size() + 1;
      }
      
      function didLeave() {
         let newMembers = getIncomingData().members;
         let oldMembers = getExistingData().members;
         // The leaving member's UID must NOT be in the new list
         return !(request.auth.uid in newMembers) &&
                // The leaving member's UID MUST have been in the old list
                request.auth.uid in oldMembers &&
                // The new list size must be one less than the old one
                newMembers.size() == oldMembers.size() - 1;
      }

      // READ: Any user can view or list groups.
      allow get, list: if true;
      
      // CREATE: A signed-in user can create a group.
      // - Their UID must be the only one in the members map.
      allow create: if isSignedIn() 
                      && getIncomingData().members.size() == 1
                      && request.auth.uid in getIncomingData().members;
      
      // UPDATE: Logic for joining, leaving, or updating group info.
      allow update: if isSignedIn() && (
        // Case 1: A user is joining the group, and the group is not full.
        (
          didJoin() &&
          getExistingData().members.size() < getExistingData().groupSizeLimit
        ) ||
        // Case 2: A user is leaving the group.
        (
          didLeave()
        ) ||
        // Case 3: A current member is updating other fields (NOT members list).
        (
          isGroupMember() &&
          getIncomingData().members == getExistingData().members // Member list is unchanged
        )
      );
      
      // DELETE: Not allowed for now to prevent accidental data loss.
      allow delete: if false;

      // Rule for querying groups a user is a member of
      match /learning_groups/{learningGroupId} {
        allow list: if request.query.where.array_contains == request.auth.uid;
      }
    }
  }
}

    