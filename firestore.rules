/**
 * @fileOverview Firestore Security Rules for w3Develops application.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for user profiles and a shared-access model for learning groups.
 *
 * Data Structure:
 * - User profiles are a single document located at /users/{userId}/profile/data, ensuring only the authenticated user can access their own profile.
 * - Learning groups are stored in a top-level /learning_groups/{learningGroupId} collection. Access is controlled by a list of member objects stored directly in the document.
 * - Counters for group naming are stored in a top-level /counters collection.
 *
 * Key Security Decisions:
 * - Users can only manage their own profiles.
 * - Learning groups are accessible to members listed in the 'members' array.
 * - Data validation is limited to authorization-critical fields to enable rapid prototyping.
 *
 * Denormalization for Authorization:
 * - The 'members' array in the 'LearningGroup' document contains denormalized user data to avoid costly 'get()' calls when checking group membership.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    
    function getMember(memberList, userId) {
      return memberList.filter(member -> member.userId == userId)[0];
    }
    
    function isMember(userId) {
      return resource.data.members.filter(member -> member.userId == userId).size() > 0;
    }

    match /users/{userId}/profile/data {
      function isOwner() {
        return request.auth != null && request.auth.uid == userId;
      }

      allow get: if isOwner() || isSignedIn(); // Allow other signed in users to view profiles
      allow list: if false; 

      allow create: if isOwner(); // User can only create their own profile doc
      allow update: if isOwner() && request.resource.data.userId == resource.data.userId && request.resource.data.username == resource.data.username;
      allow delete: if isOwner();
    }

    match /usernames/{username} {
      allow get;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }
    
    match /counters/{counterId} {
      allow read, write: if isSignedIn(); // Allow any signed-in user to read/write counters for group creation
    }

    match /learning_groups/{learningGroupId} {
      
      function incomingMembers() {
        return request.resource.data.members;
      }
      
      function currentMembers() {
        return resource.data.members;
      }

      function isJoining() {
        let isNotMember = isSignedIn() && !isMember(request.auth.uid);
        let groupNotFull = currentMembers().size() < resource.data.groupSizeLimit;

        // Ensure incoming list has exactly one new member: the current user.
        let isAddingSelf = incomingMembers().size() == currentMembers().size() + 1
                           && incomingMembers().hasAny([getMember(incomingMembers(), request.auth.uid)])
                           && currentMembers().hasAll(incomingMembers().removeAll([getMember(incomingMembers(), request.auth.uid)]));
                           
        return isNotMember && groupNotFull && isAddingSelf;
      }

       function isLeaving() {
        let wasMember = isSignedIn() && isMember(request.auth.uid);
        
        // Ensure incoming list is the current list minus the current user.
        let isRemovingSelf = incomingMembers().size() == currentMembers().size() - 1
                             && !incomingMembers().hasAny([getMember(currentMembers(), request.auth.uid)])
                             && incomingMembers().hasAll(currentMembers().removeAll([getMember(currentMembers(), request.auth.uid)]));

        return wasMember && isRemovingSelf;
      }

      function canUpdate() {
        // Allow members to update, but not change critical fields like members (except for leaving/joining)
        let isMemberUpdate = isMember(request.auth.uid) && request.resource.data.keys().diff(['members']).size() > 0 && incomingMembers() == currentMembers();
        return isMemberUpdate;
      }
      
      allow get, list: if true;
      allow create: if isSignedIn() && getMember(incomingMembers(), request.auth.uid) != null && incomingMembers().size() == 1;
      allow update: if canUpdate() || isJoining() || isLeaving();
      allow delete: if isMember(request.auth.uid);
    }
  }
}
