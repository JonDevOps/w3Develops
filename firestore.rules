/**
 * @fileOverview Firestore Security Rules for w3Develops application.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for user profiles and a shared-access model for learning groups.
 *
 * Data Structure:
 * - User profiles are a single document located at /users/{userId}/profile/data, ensuring only the authenticated user can access their own profile.
 * - Learning groups are stored in a top-level /learning_groups/{learningGroupId} collection. Access is controlled by a list of member IDs stored directly in the document.
 * - Counters for group naming are stored in a top-level /counters collection.
 *
 * Key Security Decisions:
 * - Users can only manage their own profiles.
 * - Learning groups are accessible to members listed in the 'memberIds' array.
 * - Data validation is limited to authorization-critical fields to enable rapid prototyping.
 *
 * Denormalization for Authorization:
 * - The 'memberIds' array in the 'LearningGroup' document is used to avoid costly 'get()' calls when checking group membership.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    match /users/{userId}/profile/data {
      function isOwner() {
        return request.auth != null && request.auth.uid == userId;
      }

      allow get: if isOwner() || isSignedIn(); // Allow other signed in users to view profiles
      allow list: if false; 

      allow create: if isOwner(); // User can only create their own profile doc
      allow update: if isOwner() && request.resource.data.userId == resource.data.userId && request.resource.data.username == resource.data.username;
      allow delete: if isOwner();
    }

    match /usernames/{username} {
      allow get;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }
    
    match /counters/{counterId} {
      allow read, write: if isSignedIn(); // Allow any signed-in user to read/write counters for group creation
    }

    match /learning_groups/{learningGroupId} {
      function isMember() {
          return isSignedIn() && request.auth.uid in resource.data.memberIds;
      }
      
      function isJoining() {
        let isNotMember = isSignedIn() && !(request.auth.uid in resource.data.memberIds);
        let groupNotFull = resource.data.memberIds.size() < resource.data.groupSizeLimit;
        let incomingMembers = request.resource.data.memberIds;
        // This rule ensures that a user can only add themselves to the group.
        let onlyJoining = incomingMembers.size() == resource.data.memberIds.size() + 1 && incomingMembers.hasAll(resource.data.memberIds) && incomingMembers.hasAll([request.auth.uid]);

        return isNotMember && groupNotFull && onlyJoining;
      }

       function isLeaving() {
        let wasMember = isSignedIn() && request.auth.uid in resource.data.memberIds;
        let incomingMembers = request.resource.data.memberIds;
        let onlyLeaving = incomingMembers.size() == resource.data.memberIds.size() - 1 && !incomingMembers.hasAny([request.auth.uid]) && resource.data.memberIds.hasAll(incomingMembers);
        
        return wasMember && onlyLeaving;
      }

      function canUpdate() {
        // Allow members to update, but not change critical fields like memberIds (except for leaving/joining)
        let isMemberUpdate = isMember() && request.resource.data.keys().diff(['memberIds']).size() > 0 && request.resource.data.memberIds == resource.data.memberIds;
        return isMemberUpdate;
      }
      
      allow get, list: if true;
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.memberIds && request.resource.data.memberIds.size() == 1;
      allow update: if canUpdate() || isJoining() || isLeaving();
      allow delete: if isMember();
    }
  }
}
