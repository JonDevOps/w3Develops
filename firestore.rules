rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users can read all profiles, but only write to their own.
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Allow public read on study groups.
    // Allow creation if user is authenticated and provides valid data.
    match /studyGroups/{groupId} {
      allow read: if true;
      allow create: if request.auth != null 
                    && request.resource.data.name is string
                    && request.resource.data.name_lowercase is string
                    && request.resource.data.topic is string
                    && request.resource.data.commitment is string
                    && request.resource.data.createdAt == request.time
                    && request.resource.data.memberIds is list
                    && request.resource.data.memberIds.size() == 1
                    && request.resource.data.memberIds[0] == request.auth.uid;
      // Allow a user to join a group (add themselves to memberIds), if the group is not full.
      allow update: if request.auth != null
                    && resource.data.memberIds.size() < 25
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberIds'])
                    && request.resource.data.memberIds.size() == resource.data.memberIds.size() + 1
                    && request.auth.uid in request.resource.data.memberIds
                    && !(request.auth.uid in resource.data.memberIds);
    }

    // Allow public read on cohorts.
    // Allow creation if user is authenticated and provides valid data.
    match /cohorts/{cohortId} {
      allow read: if true;
      allow create: if request.auth != null 
                    && request.resource.data.name is string
                    && request.resource.data.name_lowercase is string
                    && request.resource.data.topic is string
                    && request.resource.data.commitment is string
                    && request.resource.data.createdAt == request.time
                    && request.resource.data.memberIds is list
                    && request.resource.data.memberIds.size() == 1
                    && request.resource.data.memberIds[0] == request.auth.uid;
      // Allow a user to join a cohort (add themselves to memberIds), if the cohort is not full.
      allow update: if request.auth != null
                    && resource.data.memberIds.size() < 25
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberIds'])
                    && request.resource.data.memberIds.size() == resource.data.memberIds.size() + 1
                    && request.auth.uid in request.resource.data.memberIds
                    && !(request.auth.uid in resource.data.memberIds);
    }
  }
}
