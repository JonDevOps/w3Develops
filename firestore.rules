rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Helper function for list operations
    function isAddingToList(request, field) {
      let list = resource.data[field];
      let newList = request.resource.data[field];
      return newList.size() == list.size() + 1 && newList.hasAll(list);
    }
    
    // Users can read all profiles, but only write to their own data.
    match /users/{userId} {
      allow read: if true;
      // Allow creation/deletion (for signup/account deletion)
      allow create, delete: if isOwner(userId);
      // Allow updates to most fields by the owner
      allow update: if isOwner(userId) && (
        // Standard profile updates
        (request.resource.data.keys().hasOnly([
            'bio', 'skills', 'socialLinks', 'followInfoPrivate', 'lastLoginAt', 'lastLogoutAt', 
            'profilePictureUrl', 'isSubscribedToNewsletter',
            'email', 'username', 'username_lowercase', 'createdAt', 'followers', 'following',
            'createdStudyGroupIds', 'joinedStudyGroupIds', 'createdCohortIds', 'joinedCohortIds'
        ])) ||
        // Transactional updates for joining/creating groups/cohorts
        (isAddingToList(request, 'createdStudyGroupIds')) ||
        (isAddingToList(request, 'joinedStudyGroupIds')) ||
        (isAddingToList(request, 'createdCohortIds')) ||
        (isAddingToList(request, 'joinedCohortIds'))
      );
    }
    
    // Allow public read on study groups.
    match /studyGroups/{groupId} {
      allow read: if true;
      allow create: if request.auth != null 
                    && request.resource.data.keys().hasOnly(['name', 'name_lowercase', 'topic', 'commitment', 'description', 'createdAt', 'memberIds', 'creatorId'])
                    && request.resource.data.name is string
                    && request.resource.data.name_lowercase is string
                    && request.resource.data.creatorId == request.auth.uid
                    && request.resource.data.topic is string
                    && request.resource.data.commitment is string
                    && request.resource.data.description is string
                    && request.resource.data.createdAt == request.time
                    && request.resource.data.memberIds is list
                    && request.resource.data.memberIds.size() == 1
                    && request.resource.data.memberIds[0] == request.auth.uid;
      // Allow a user to join a group (add themselves to memberIds), if the group is not full and is less than 7 days old.
      allow update: if request.auth != null
                    && resource.data.memberIds.size() < 25
                    && request.time - resource.data.createdAt < duration.value(7, 'd')
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberIds'])
                    && isAddingToList(request, 'memberIds');
    }

    // Allow public read on cohorts.
    match /cohorts/{cohortId} {
      allow read: if true;
      allow create: if request.auth != null 
                    && request.resource.data.keys().hasOnly(['name', 'name_lowercase', 'topic', 'commitment', 'githubUrl', 'description', 'createdAt', 'memberIds', 'creatorId'])
                    && request.resource.data.name is string
                    && request.resource.data.name_lowercase is string
                    && request.resource.data.creatorId == request.auth.uid
                    && request.resource.data.topic is string
                    && request.resource.data.commitment is string
                    && request.resource.data.githubUrl is string
                    && request.resource.data.description is string
                    && request.resource.data.createdAt == request.time
                    && request.resource.data.memberIds is list
                    && request.resource.data.memberIds.size() == 1
                    && request.resource.data.memberIds[0] == request.auth.uid;
      // Allow a user to join a cohort (add themselves to memberIds), if the cohort is not full and is less than 7 days old.
      allow update: if request.auth != null
                    && resource.data.memberIds.size() < 25
                    && request.time - resource.data.createdAt < duration.value(7, 'd')
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberIds'])
                    && isAddingToList(request, 'memberIds');
    }
    
    // Notifications subcollection
    match /users/{userId}/notifications/{notificationId} {
      // A user can only access their own notifications.
      allow read, write: if isOwner(userId);
    }
  }
}
