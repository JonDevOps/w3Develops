
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getIncomingData() {
      return request.resource.data;
    }
    
    function getExistingData() {
      return resource.data;
    }
    
    // --- User Profile Rules (/users/{userId}) ---
    match /users/{userId} {
      allow get: if isSignedIn();
      allow create: if isOwner(userId) && getIncomingData().userId == userId;
      allow update: if isOwner(userId) 
                      && getIncomingData().userId == getExistingData().userId
                      && getIncomingData().username == getExistingData().username;
      allow delete: if isOwner(userId);
      allow list: if false;
    }

    // --- Username Uniqueness Rules (/usernames/{username}) ---
    match /usernames/{username} {
      allow get: if true;
      allow create: if isSignedIn() && getIncomingData().userId == request.auth.uid;
      allow update, delete: if false;
    }
  }
}
