rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Allow any authenticated user to read user profiles.
    // Users can only write to their own profile.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Any authenticated user can read study groups and cohorts.
    match /studyGroups/{groupId} {
      allow read: if request.auth != null;
      // Allow create if user is first member.
      // Allow update (joining) if user is adding themselves and group is not full.
      // Allow update (leaving) if user is removing themselves.
      // Allow update by members for other fields (e.g. description).
      allow create: if request.auth != null && request.resource.data.memberIds[0] == request.auth.uid;
      allow update: if request.auth != null && (
        ( // Joining
          request.resource.data.memberIds == resource.data.memberIds.concat([request.auth.uid]) &&
          resource.data.memberIds.size() < 25
        ) ||
        ( // Leaving
          request.resource.data.memberIds == resource.data.memberIds.diff([request.auth.uid])
        ) ||
        ( // Other updates by members
          request.auth.uid in resource.data.memberIds
        )
      );
    }

    match /cohorts/{cohortId} {
      allow read: if request.auth != null;
       // Allow create if user is first member.
      // Allow update (joining) if user is adding themselves and group is not full.
      // Allow update (leaving) if user is removing themselves.
      // Allow update by members for other fields (e.g. description).
      allow create: if request.auth != null && request.resource.data.memberIds[0] == request.auth.uid;
      allow update: if request.auth != null && (
        ( // Joining
          request.resource.data.memberIds == resource.data.memberIds.concat([request.auth.uid]) &&
          resource.data.memberIds.size() < 25
        ) ||
        ( // Leaving
          request.resource.data.memberIds == resource.data.memberIds.diff([request.auth.uid])
        ) ||
        ( // Other updates by members
          request.auth.uid in resource.data.memberIds
        )
      );
    }
  }
}
