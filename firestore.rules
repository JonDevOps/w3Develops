/**
 * @fileOverview Firestore Security Rules for w3Develops application.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for user profiles and a shared-access model for learning groups.
 *
 * Data Structure:
 * - User profiles are a single document located at /users/{userId}/profile/data, ensuring only the authenticated user can access their own profile.
 * - Learning groups are stored in a top-level /learning_groups/{learningGroupId} collection. Access is controlled by a list of member IDs stored directly in the document.
 *
 * Key Security Decisions:
 * - Users can only manage their own profiles.
 * - Learning groups are accessible to members listed in the 'memberIds' array.
 * - Data validation is limited to authorization-critical fields to enable rapid prototyping.
 *
 * Denormalization for Authorization:
 * - The 'memberIds' array in the 'LearningGroup' document is used to avoid costly 'get()' calls when checking group membership.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to user profile information.
     * @path /users/{userId}/profile/data
     * @allow (create) User with UID 'user_abc' can create their own profile with userId: 'user_abc'.
     * @allow (get, update, delete) User with UID 'user_abc' can get, update, and delete their own profile.
     * @deny (create, update, delete) User with UID 'user_xyz' cannot create, update, or delete 'user_abc' profile.
     * @principle Enforces document ownership for writes, restricts access to a user's own data tree, and validates relational integrity between documents.
     */
    match /users/{userId}/profile/data {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if false; // Not intended to be listable

      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Controls access to learning group data.
     * @path /learning_groups/{learningGroupId}
     * @allow (get, list) Any signed-in user can read group information.
     * @allow (create) A user can create a learning group. The 'memberIds' should contain creator's id.
     * @allow (update) A user can join a group if they are authenticated and the group is not full.
     * @allow (delete) Only members of the learning group can delete it.
     * @deny (create) A user cannot create a group if their ID isn't in 'memberIds'.
     * @deny (update) A non-member cannot update the group unless they are joining.
     * @deny (delete) A non-member cannot delete the learning group.
     * @principle Enforces shared access based on the 'memberIds' array, enabling secure group management.
     */
    match /learning_groups/{learningGroupId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isMember() {
          return isSignedIn() && request.auth.uid in resource.data.memberIds;
      }
      
      function isJoining() {
        let incomingMembers = request.resource.data.memberIds;
        let existingMembers = resource.data.memberIds;
        return isSignedIn() 
               && incomingMembers.size() == existingMembers.size() + 1
               && incomingMembers.hasAll(existingMembers)
               && incomingMembers.hasAll([request.auth.uid])
               && request.resource.data.size() == resource.data.size();
      }

      function isExistingMember() {
        return isMember() && resource != null;
      }

      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.memberIds.hasAll([request.auth.uid]);
      allow update: if isExistingMember() || isJoining();
      allow delete: if isExistingMember();
    }
  }
}
