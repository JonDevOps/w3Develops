
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getIncomingData() {
      return request.resource.data;
    }
    
    function getExistingData() {
      return resource.data;
    }
    
    // --- User Profile Rules (/users/{userId}) ---
    match /users/{userId} {
      // READ: Any signed-in user can view a profile.
      allow get: if isSignedIn();
      
      // CREATE: A user can only create their own profile.
      // - The new document's userId must match their auth uid.
      allow create: if isOwner(userId) && getIncomingData().userId == userId;
      
      // UPDATE: A user can only update their own profile.
      // - Critical fields like userId and username must not be changed.
      allow update: if isOwner(userId) 
                      && getIncomingData().userId == getExistingData().userId
                      && getIncomingData().username == getExistingData().username;

      // DELETE: A user can delete their own profile.
      allow delete: if isOwner(userId);

      // LIST: Listing all user profiles is disallowed for security.
      allow list: if false;
    }

    // --- Username Uniqueness Rules (/usernames/{username}) ---
    match /usernames/{username} {
      // READ: Anyone can check if a username exists.
      allow get: if true;
      
      // CREATE: A user can claim a username if it's not taken.
      // - The new document's userId must match their auth uid.
      allow create: if isSignedIn() && getIncomingData().userId == request.auth.uid;
      
      // UPDATE/DELETE: Not allowed to prevent tampering.
      allow update, delete: if false;
    }
    
    // --- Counter Rules (/counters/{counterId}) ---
    match /counters/{counterId} {
      // Any signed-in user can read or write to counters for group creation purposes.
      allow read, write: if isSignedIn();
    }

    // --- Learning Group Rules (/learning_groups/{learningGroupId}) ---
    match /learning_groups/{learningGroupId} {
      
      // --- Helper Functions for Groups ---
      function isGroupMember(userId) {
        return userId in getExistingData().members.map(member => member.userId);
      }
      
      function isNewMemberListValid(currentMembers, newMembers) {
          return newMembers.size() == currentMembers.size() + 1
                 && newMembers.hasAny(currentMembers) == false;
      }
      
      function isLeaving(currentMembers, newMembers) {
         return newMembers.size() == currentMembers.size() - 1 &&
                currentMembers.hasAll(newMembers);
      }
      
      function didJoin(currentMembers, newMembers) {
        let joinedUser = newMembers.diff(currentMembers).added().get(
            currentMembers.diff(newMembers).removed().keys()[0]
        );
        return newMembers.size() == currentMembers.size() + 1 &&
               currentMembers.hasAll(newMembers.removeAll([joinedUser])) &&
               joinedUser.userId == request.auth.uid;
      }

      // READ: Any user can view or list groups.
      allow get, list: if true;
      
      // CREATE: A signed-in user can create a group.
      // - They must be the first and only member upon creation.
      allow create: if isSignedIn() 
                      && getIncomingData().members.size() == 1
                      && getIncomingData().members[0].userId == request.auth.uid;
      
      // UPDATE: Logic for joining, leaving, or updating group info.
      allow update: if isSignedIn() && (
        // Case 1: A user is joining the group.
        (
          !isGroupMember(request.auth.uid) && // User is not already a member
          getExistingData().members.size() < getExistingData().groupSizeLimit && // Group is not full
          didJoin(getExistingData().members, getIncomingData().members)
        ) ||
        // Case 2: A user is leaving the group.
        (
          isGroupMember(request.auth.uid) &&
          isLeaving(getExistingData().members, getIncomingData().members)
        ) ||
        // Case 3: A current member is updating other fields (NOT members list).
        (
          isGroupMember(request.auth.uid) &&
          getIncomingData().members == getExistingData().members // Member list is unchanged
        )
      );
      
      // DELETE: Not allowed for now to prevent accidental data loss.
      // Can be changed to `if isGroupMember(request.auth.uid)` to allow members to delete.
      allow delete: if false;
    }
  }
}
