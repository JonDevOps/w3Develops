rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }
    
    // Users can read all profiles, but only write to their own data.
    match /users/{userId} {
      allow read: if true;
      // Allow creation/deletion (for signup/account deletion)
      allow create, delete: if isOwner(userId);
      // Allow updates to most fields by the owner
      allow update: if isOwner(userId) && request.resource.data.keys().hasOnly([
        'bio', 'skills', 'socialLinks', 'followInfoPrivate', 'lastLoginAt', 'lastLogoutAt', 'profilePictureUrl', 'isSubscribedToNewsletter',
        'email', 'username', 'username_lowercase', 'createdAt', 'followers', 'following' // Can't change these
      ]);
    }
    
    // Allow public read on study groups.
    match /studyGroups/{groupId} {
      allow read: if true;
      allow create: if request.auth != null 
                    && request.resource.data.keys().hasOnly(['name', 'name_lowercase', 'topic', 'commitment', 'description', 'createdAt', 'memberIds'])
                    && request.resource.data.name is string
                    && request.resource.data.name_lowercase is string
                    && request.resource.data.topic is string
                    && request.resource.data.commitment is string
                    && request.resource.data.description is string
                    && request.resource.data.createdAt == request.time
                    && request.resource.data.memberIds is list
                    && request.resource.data.memberIds.size() == 1
                    && request.resource.data.memberIds[0] == request.auth.uid;
      // Allow a user to join a group (add themselves to memberIds), if the group is not full and is less than 7 days old.
      allow update: if request.auth != null
                    && resource.data.memberIds.size() < 25
                    && request.time - resource.data.createdAt < duration.value(7, 'd')
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberIds'])
                    && request.resource.data.memberIds == resource.data.memberIds.concat([request.auth.uid]);
    }

    // Allow public read on cohorts.
    match /cohorts/{cohortId} {
      allow read: if true;
      allow create: if request.auth != null 
                    && request.resource.data.keys().hasOnly(['name', 'name_lowercase', 'topic', 'commitment', 'githubUrl', 'description', 'createdAt', 'memberIds'])
                    && request.resource.data.name is string
                    && request.resource.data.name_lowercase is string
                    && request.resource.data.topic is string
                    && request.resource.data.commitment is string
                    && request.resource.data.githubUrl is string
                    && request.resource.data.description is string
                    && request.resource.data.createdAt == request.time
                    && request.resource.data.memberIds is list
                    && request.resource.data.memberIds.size() == 1
                    && request.resource.data.memberIds[0] == request.auth.uid;
      // Allow a user to join a cohort (add themselves to memberIds), if the cohort is not full and is less than 7 days old.
      allow update: if request.auth != null
                    && resource.data.memberIds.size() < 25
                    && request.time - resource.data.createdAt < duration.value(7, 'd')
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberIds'])
                    && request.resource.data.memberIds == resource.data.memberIds.concat([request.auth.uid]);
    }

    // Rules for Follow/Unfollow Transaction
    match /functions/{functionName} {
      // Allow authenticated users to call the 'followUser' callable function.
      // The function itself will contain the security logic.
      allow call: if request.auth != null;
    }
    
    // Notifications subcollection
    match /users/{userId}/notifications/{notificationId} {
      // A user can only access their own notifications.
      allow read, write: if isOwner(userId);
    }
  }
}
