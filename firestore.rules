rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users can read and write to their own profile.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Any authenticated user can read study groups and cohorts.
    match /studyGroups/{groupId} {
      allow read: if request.auth != null;
      // Anyone can create. Only members can update.
      allow write: if request.auth != null && (request.resource.data.memberIds[0] == request.auth.uid || request.auth.uid in resource.data.memberIds);
    }

    match /cohorts/{cohortId} {
      allow read: if request.auth != null;
      // Anyone can create. Only members can update.
      allow write: if request.auth != null && (request.resource.data.memberIds[0] == request.auth.uid || request.auth.uid in resource.data.memberIds);
    }
  }
}
