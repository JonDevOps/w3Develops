
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user's profile within the w3Develops application.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the UserProfile entity."
        },
        "email": {
          "type": "string",
          "description": "User's email address.",
          "format": "email"
        },
        "username": {
          "type": "string",
          "description": "User's unique username."
        },
        "username_lowercase": {
          "type": "string",
          "description": "Lowercase version of the user's username for searching and uniqueness checks."
        },
        "profilePictureUrl": {
          "type": "string",
          "description": "URL of the user's profile picture.",
          "format": "uri"
        },
        "bio": {
          "type": "string",
          "description": "A short biography or description about the user."
        },
        "socialLinks": {
          "type": "object",
          "description": "An object containing social media links.",
          "properties": {
            "github": {
              "type": "string",
              "format": "uri"
            },
            "linkedin": {
              "type": "string",
              "format": "uri"
            },
            "twitter": {
              "type": "string",
              "format": "uri"
            }
          }
        },
        "skills": {
          "type": "array",
          "description": "A list of the user's skills.",
          "items": {
            "type": "string"
          }
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the user profile was created."
        },
        "lastLoginAt": {
            "type": "string",
            "format": "date-time",
            "description": "The timestamp of the user's last login."
        },
        "lastLogoutAt": {
            "type": "string",
            "format": "date-time",
            "description": "The timestamp of the user's last logout."
        },
        "followers": {
          "type": "array",
          "description": "A list of user IDs that are following this user.",
          "items": {
            "type": "string"
          }
        },
        "following": {
          "type": "array",
          "description": "A list of user IDs that this user is following.",
          "items": {
            "type": "string"
          }
        },
        "followInfoPrivate": {
          "type": "boolean",
          "description": "If true, the user's follower and following lists are private."
        },
        "createdStudyGroupIds": {
            "type": "array",
            "description": "A list of StudyGroup IDs created by this user.",
            "items": { "type": "string" }
        },
        "joinedStudyGroupIds": {
            "type": "array",
            "description": "A list of StudyGroup IDs this user has joined (but not created).",
            "items": { "type": "string" }
        },
        "createdCohortIds": {
            "type": "array",
            "description": "A list of Cohort IDs created by this user.",
            "items": { "type": "string" }
        },
        "joinedCohortIds": {
            "type": "array",
            "description": "A list of Cohort IDs this user has joined (but not created).",
            "items": { "type": "string" }
        },
        "isSubscribedToNewsletter": {
            "type": "boolean"
        }
      },
      "required": [
        "id",
        "email",
        "username",
        "username_lowercase",
        "createdAt"
      ]
    },
    "StudyGroup": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "StudyGroup",
      "type": "object",
      "description": "Represents a study group within the w3Develops application.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the StudyGroup entity."
        },
        "name": {
          "type": "string",
          "description": "Name of the study group."
        },
        "name_lowercase": {
          "type": "string",
          "description": "Lowercase version of the group name for case-insensitive searching."
        },
        "creatorId": {
          "type": "string",
          "description": "The ID of the user who created the group."
        },
        "description": {
          "type": "string",
          "description": "Description of the study group's focus or purpose."
        },
        "memberIds": {
          "type": "array",
          "description": "References to UserProfiles. (Relationship: UserProfile N:N StudyGroup)",
          "items": {
            "type": "string"
          }
        },
        "topic": {
          "type": "string",
          "description": "The primary topic associated with this study group."
        },
        "commitment": {
          "type": "string",
          "description": "The expected time commitment for the group."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the group was created."
        }
      },
      "required": [
        "id",
        "name",
        "name_lowercase",
        "creatorId",
        "topic",
        "commitment",
        "createdAt"
      ]
    },
    "Cohort": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Cohort",
      "type": "object",
      "description": "Represents a project cohort created by a user.",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "name_lowercase": {
          "type": "string",
          "description": "Lowercase version of the cohort name for case-insensitive searching."
        },
        "creatorId": {
          "type": "string",
          "description": "The ID of the user who created the cohort."
        },
        "description": {
          "type": "string"
        },
        "memberIds": {
          "type": "array",
          "description": "References to UserProfiles who are members of the cohort.",
          "items": {
            "type": "string"
          }
        },
        "githubUrl": {
          "type": "string",
          "format": "uri"
        },
        "topic": {
          "type": "string",
          "description": "The primary topic associated with this cohort."
        },
        "commitment": {
          "type": "string",
          "description": "The expected time commitment for the cohort."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the cohort was created."
        }
      },
      "required": [
        "id",
        "name",
        "name_lowercase",
        "creatorId",
        "topic",
        "commitment",
        "createdAt"
      ]
    },
    "Task": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Task",
      "type": "object",
      "description": "Represents a task within a study group or project cohort.",
      "properties": {
        "id": { "type": "string" },
        "description": { "type": "string" },
        "isCompleted": { "type": "boolean" },
        "priority": { "type": "string", "enum": ["low", "medium", "high"] },
        "creatorId": { "type": "string" },
        "completedBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "completedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "description", "isCompleted", "priority", "creatorId", "createdAt"]
    },
    "Notification": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Notification",
      "type": "object",
      "description": "Represents a user notification.",
      "properties": {
        "id": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "isRead": {
          "type": "boolean"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "link": {
          "type": "string",
          "format": "uri-reference"
        }
      },
      "required": ["id", "message", "isRead", "createdAt"]
    },
    "Feedback": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Feedback",
      "type": "object",
      "description": "Represents user-submitted feedback for the site.",
      "properties": {
        "id": {
          "type": "string"
        },
        "feedback": {
          "type": "string",
          "description": "The main content of the feedback submission."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the feedback was submitted."
        },
        "userId": {
          "type": "string",
          "description": "The ID of the user who submitted the feedback (if logged in)."
        },
        "username": {
            "type": "string",
            "description": "The username of the user who submitted the feedback (if logged in)."
        }
      },
      "required": ["id", "feedback", "createdAt"]
    },
    "SupportRequest": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "title": "SupportRequest",
        "type": "object",
        "description": "Represents a user-submitted support request.",
        "properties": {
            "id": { "type": "string" },
            "userId": { "type": "string" },
            "username": { "type": "string" },
            "email": { "type": "string", "format": "email" },
            "subject": { "type": "string" },
            "description": { "type": "string" },
            "status": { "type": "string", "enum": ["open", "in_progress", "closed"] },
            "createdAt": { "type": "string", "format": "date-time" }
        },
        "required": ["id", "userId", "username", "email", "subject", "description", "status", "createdAt"]
    }
  },
  "auth": {
    "providers": [
      "password"
    ]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/UserProfile"
      },
      "description": "Stores user profile data."
    },
    "/studyGroups/{groupId}": {
      "schema": {
        "$ref": "#/entities/StudyGroup"
      },
      "description": "Stores study group data."
    },
    "/cohorts/{cohortId}": {
      "schema": {
        "$ref": "#/entities/Cohort"
      },
      "description": "Stores project cohort data."
    },
    "/studyGroups/{groupId}/tasks/{taskId}": {
        "schema": {
            "$ref": "#/entities/Task"
        },
        "description": "Stores tasks for a specific study group."
    },
    "/cohorts/{cohortId}/tasks/{taskId}": {
        "schema": {
            "$ref": "#/entities/Task"
        },
        "description": "Stores tasks for a specific project cohort."
    },
    "/users/{userId}/notifications/{notificationId}": {
        "schema": {
            "$ref": "#/entities/Notification"
        },
        "description": "Stores notifications for a specific user."
    },
    "/feedback/{feedbackId}": {
      "schema": {
        "$ref": "#/entities/Feedback"
      },
      "description": "Stores user-submitted feedback."
    },
    "/supportRequests/{supportRequestId}": {
        "schema": {
            "$ref": "#/entities/SupportRequest"
        },
        "description": "Stores user-submitted technical support requests."
    }
  }
}

    