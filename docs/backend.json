{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user's profile information.",
      "properties": {
        "userId": {
          "type": "string",
          "description": "Reference to the user's ID in the authentication system."
        },
        "username": {
          "type": "string",
          "description": "The user's unique, public-facing username."
        },
        "displayName": {
          "type": "string",
          "description": "The user's full name."
        },
        "profilePictureUrl": {
          "type": "string",
          "description": "URL of the user's profile picture.",
          "format": "uri"
        },
        "socialLinks": {
          "type": "array",
          "description": "An array of social media links.",
          "items": {
            "type": "string",
            "format": "uri"
          }
        },
        "bio": {
          "type": "string",
          "description": "A short biography of the user."
        },
        "portfolioUrl": {
          "type": "string",
          "format": "uri",
          "description": "URL of the user's portfolio or personal website."
        },
        "projects": {
          "type": "array",
          "description": "A list of projects the user is working on.",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "userId",
        "username",
        "displayName"
      ]
    },
    "Username": {
      "title": "Username",
      "type": "object",
      "description": "A document to enforce username uniqueness.",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The ID of the user who owns this username."
        }
      },
      "required": [
        "userId"
      ]
    },
    "LearningGroup": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "LearningGroup",
      "type": "object",
      "description": "Represents a learning group.",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the learning group."
        },
        "primarySkill": {
          "type": "string",
          "description": "The primary skill focus of the group."
        },
        "timeCommitment": {
          "type": "string",
          "enum": [
            "part-time",
            "full-time"
          ],
          "description": "The expected time commitment for the group."
        },
        "members": {
          "type": "array",
          "description": "An array of member objects, containing their ID, username, and profile picture URL.",
          "items": {
            "type": "object",
            "properties": {
              "userId": { "type": "string" },
              "username": { "type": "string" },
              "profilePictureUrl": { "type": "string", "format": "uri" }
            },
            "required": ["userId", "username"]
          }
        },
        "groupSizeLimit": {
          "type": "number",
          "description": "The maximum number of members allowed in the group.",
          "default": 25
        },
        "description": {
          "type": "string",
          "description": "A description of the learning group."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the group was created."
        }
      },
      "required": [
        "name",
        "primarySkill",
        "members",
        "createdAt",
        "groupSizeLimit",
        "timeCommitment"
      ]
    },
     "GroupCounter": {
      "title": "Group Counter",
      "type": "object",
      "description": "A document to store the count for a specific type of group.",
      "properties": {
        "count": {
          "type": "number",
          "description": "The current number of groups of this type."
        }
      },
      "required": ["count"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}/profile/data",
        "definition": {
          "schema": {
            "$ref": "#/entities/UserProfile"
          },
          "description": "Stores a single user profile information document."
        }
      },
      {
        "path": "/usernames/{username}",
        "definition": {
          "schema": {
            "$ref": "#/entities/Username"
          },
          "description": "A collection to enforce unique usernames. The document ID is the username itself."
        }
      },
      {
        "path": "/learning_groups/{learningGroupId}",
        "definition": {
          "schema": {
            "$ref": "#/entities/LearningGroup"
          },
          "description": "Stores learning group data."
        }
      },
      {
        "path": "/counters/{counterId}",
        "definition": {
          "schema": {
            "$ref": "#/entities/GroupCounter"
          },
          "description": "Stores counters for naming learning groups uniquely."
        }
      }
    ]
  }
}
