
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user's profile within the w3Develops application.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the UserProfile entity."
        },
        "email": {
          "type": "string",
          "description": "User's email address.",
          "format": "email"
        },
        "username": {
          "type": "string",
          "description": "User's unique username."
        },
        "username_lowercase": {
          "type": "string",
          "description": "Lowercase version of the user's username for searching and uniqueness checks."
        },
        "profilePictureUrl": {
          "type": "string",
          "description": "URL of the user's profile picture.",
          "format": "uri"
        },
        "bio": {
          "type": "string",
          "description": "A short biography or description about the user."
        },
        "socialLinks": {
          "type": "object",
          "description": "An object containing social media links.",
          "properties": {
            "github": {
              "type": "string",
              "format": "uri"
            },
            "linkedin": {
              "type": "string",
              "format": "uri"
            },
            "twitter": {
              "type": "string",
              "format": "uri"
            }
          }
        },
        "skills": {
          "type": "array",
          "description": "A list of the user's skills.",
          "items": {
            "type": "string"
          }
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the user profile was created."
        },
        "lastLoginAt": {
            "type": "string",
            "format": "date-time",
            "description": "The timestamp of the user's last login."
        },
        "lastLogoutAt": {
            "type": "string",
            "format": "date-time",
            "description": "The timestamp of the user's last logout."
        },
        "followers": {
          "type": "array",
          "description": "A list of user IDs that are following this user.",
          "items": {
            "type": "string"
          }
        },
        "following": {
          "type": "array",
          "description": "A list of user IDs that this user is following.",
          "items": {
            "type": "string"
          }
        },
        "followInfoPrivate": {
          "type": "boolean",
          "description": "If true, the user's follower and following lists are private."
        },
        "createdStudyGroupIds": {
            "type": "array",
            "description": "A list of StudyGroup IDs created by this user.",
            "items": { "type": "string" }
        },
        "joinedStudyGroupIds": {
            "type": "array",
            "description": "A list of StudyGroup IDs this user has joined (but not created).",
            "items": { "type": "string" }
        },
        "createdGroupProjectIds": {
            "type": "array",
            "description": "A list of GroupProject IDs created by this user.",
            "items": { "type": "string" }
        },
        "joinedGroupProjectIds": {
            "type": "array",
            "description": "A list of GroupProject IDs this user has joined (but not created).",
            "items": { "type": "string" }
        },
        "soloProjectIds": {
            "type": "array",
            "description": "A list of SoloProject IDs created by this user.",
            "items": { "type": "string" }
        },
        "starredSoloProjectIds": {
            "type": "array",
            "description": "A list of SoloProject IDs this user has starred.",
            "items": { "type": "string" }
        },
        "notificationSettings": {
            "type": "object",
            "description": "User's notification preferences.",
            "properties": {
                "dailyCodingNewsletter": { "type": "boolean" },
                "dailyJsNewsletter": { "type": "boolean" },
                "weeklyBookClub": { "type": "boolean" },
                "tipsAndTricks": { "type": "boolean" },
                "interviewQuestions": { "type": "boolean" },
                "weeklyDigest": { "type": "boolean" },
                "surveys": { "type": "boolean" }
            }
        },
        "status": {
          "type": "string",
          "enum": ["active", "paused", "inactive"],
          "description": "The user's current activity status."
        },
        "lastCheckInAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp of the user's last check-in."
        },
        "createdBookClubIds": {
          "type": "array",
          "description": "A list of BookClub IDs created by this user.",
          "items": {
            "type": "string"
          }
        },
        "joinedBookClubIds": {
          "type": "array",
          "description": "A list of BookClub IDs this user has joined (but not created).",
          "items": {
            "type": "string"
          }
        },
        "createdMeetupIds": {
          "type": "array",
          "description": "A list of Meetup IDs created by this user.",
          "items": { "type": "string" }
        },
        "joinedMeetupIds": {
            "type": "array",
            "description": "A list of Meetup IDs this user has joined (but not created).",
            "items": { "type": "string" }
        },
        "mentorshipRole": {
          "type": "string",
          "enum": [
            "none",
            "mentor",
            "mentee",
            "both"
          ],
          "description": "The user's role in the mentorship program."
        },
        "mentorshipStatus": {
          "type": "string",
          "enum": [
            "open",
            "closed"
          ],
          "description": "Whether the user is open to new mentorship requests."
        },
        "mentoringSkills": {
          "type": "array",
          "description": "Skills the user is willing to mentor in.",
          "items": {
            "type": "string"
          }
        },
        "seekingSkills": {
          "type": "array",
          "description": "Skills the user is seeking mentorship for.",
          "items": {
            "type": "string"
          }
        },
        "mentorIds": {
          "type": "array",
          "description": "A list of user IDs who are mentoring this user.",
          "items": {
            "type": "string"
          }
        },
        "menteeIds": {
          "type": "array",
          "description": "A list of user IDs this user is mentoring.",
          "items": {
            "type": "string"
          }
        },
        "mentorshipIds": {
          "type": "array",
          "description": "A list of Mentorship IDs this user is part of.",
          "items": {
            "type": "string"
          }
        },
        "tutorRole": {
          "type": "string",
          "enum": [
            "none",
            "tutor",
            "student",
            "both"
          ],
          "description": "The user's role in the tutoring program."
        },
        "tutorStatus": {
          "type": "string",
          "enum": [
            "open",
            "closed"
          ],
          "description": "Whether the user is open to new tutoring requests."
        },
        "tutoringSkills": {
          "type": "array",
          "description": "Skills the user is willing to tutor in.",
          "items": {
            "type": "string"
          }
        },
        "seekingTutoringSkills": {
          "type": "array",
          "description": "Skills the user is seeking tutoring for.",
          "items": {
            "type": "string"
          }
        },
        "tutorIds": {
          "type": "array",
          "description": "A list of user IDs who are tutoring this user.",
          "items": {
            "type": "string"
          }
        },
        "studentIds": {
          "type": "array",
          "description": "A list of user IDs this user is tutoring.",
          "items": {
            "type": "string"
          }
        },
        "tutorshipIds": {
          "type": "array",
          "description": "A list of Tutorship IDs this user is part of.",
          "items": {
            "type": "string"
          }
        },
        "pairProgrammingStatus": {
          "type": "string",
          "enum": [
            "open",
            "closed"
          ],
          "description": "Whether the user is open to new pair programming requests."
        },
        "pairProgrammingSkills": {
          "type": "array",
          "description": "Skills the user is interested in for pair programming.",
          "items": {
            "type": "string"
          }
        },
        "pairPartnerIds": {
          "type": "array",
          "description": "A list of user IDs this user is paired with.",
          "items": {
            "type": "string"
          }
        },
        "pairingIds": {
          "type": "array",
          "description": "A list of Pairing IDs this user is part of.",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "id",
        "email",
        "username",
        "username_lowercase",
        "createdAt"
      ]
    },
    "StudyGroup": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "StudyGroup",
      "type": "object",
      "description": "Represents a study group within the w3Develops application.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the StudyGroup entity."
        },
        "name": {
          "type": "string",
          "description": "Name of the study group."
        },
        "name_lowercase": {
          "type": "string",
          "description": "Lowercase version of the group name for case-insensitive searching."
        },
        "creatorId": {
          "type": "string",
          "description": "The ID of the user who created the group."
        },
        "description": {
          "type": "string",
          "description": "Description of the study group's focus or purpose."
        },
        "memberIds": {
          "type": "array",
          "description": "References to UserProfiles. (Relationship: UserProfile N:N StudyGroup)",
          "items": {
            "type": "string"
          }
        },
        "topic": {
          "type": "string",
          "description": "The primary topic associated with this study group."
        },
        "commitment": {
          "type": "string",
          "description": "The expected time commitment for the group."
        },
        "commitmentDays": {
          "type": "array",
          "description": "The days of the week for group meetings.",
          "items": {
            "type": "string"
          }
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the group was created."
        }
      },
      "required": [
        "id",
        "name",
        "name_lowercase",
        "creatorId",
        "topic",
        "commitment",
        "commitmentDays",
        "createdAt"
      ]
    },
    "BookClub": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "BookClub",
      "type": "object",
      "description": "Represents a book club within the w3Develops application.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the BookClub entity."
        },
        "name": {
          "type": "string",
          "description": "Name of the book club."
        },
        "name_lowercase": {
          "type": "string",
          "description": "Lowercase version of the club name for case-insensitive searching."
        },
        "creatorId": {
          "type": "string",
          "description": "The ID of the user who created the club."
        },
        "description": {
          "type": "string",
          "description": "Description of the book club's focus or purpose."
        },
        "memberIds": {
          "type": "array",
          "description": "References to UserProfiles.",
          "items": {
            "type": "string"
          }
        },
        "topic": {
          "type": "string",
          "description": "The book genre or topic of the club."
        },
        "commitmentHours": {
          "type": "string",
          "description": "The expected time commitment in hours per day."
        },
        "commitmentDays": {
          "type": "array",
          "description": "The days of the week for club meetings.",
          "items": {
            "type": "string"
          }
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the club was created."
        }
      },
      "required": [
        "id",
        "name",
        "name_lowercase",
        "creatorId",
        "topic",
        "commitmentHours",
        "commitmentDays",
        "createdAt"
      ]
    },
    "GroupProject": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "GroupProject",
      "type": "object",
      "description": "Represents a project created by a user.",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "name_lowercase": {
          "type": "string",
          "description": "Lowercase version of the project name for case-insensitive searching."
        },
        "creatorId": {
          "type": "string",
          "description": "The ID of the user who created the project."
        },
        "description": {
          "type": "string"
        },
        "memberIds": {
          "type": "array",
          "description": "References to UserProfiles who are members of the project.",
          "items": {
            "type": "string"
          }
        },
        "githubUrl": {
          "type": "string",
          "format": "uri"
        },
        "topic": {
          "type": "string",
          "description": "The primary topic associated with this project."
        },
        "commitment": {
          "type": "string",
          "description": "The expected time commitment for the project."
        },
        "commitmentDays": {
          "type": "array",
          "description": "The days of the week for project meetings.",
          "items": {
            "type": "string"
          }
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the project was created."
        }
      },
      "required": [
        "id",
        "name",
        "name_lowercase",
        "creatorId",
        "topic",
        "commitment",
        "commitmentDays",
        "createdAt"
      ]
    },
    "Meetup": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Meetup",
      "type": "object",
      "description": "Represents a community meetup event.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "name_lowercase": { "type": "string" },
        "creatorId": { "type": "string" },
        "description": { "type": "string" },
        "topic": { "type": "string" },
        "attendeeIds": { "type": "array", "items": { "type": "string" } },
        "dateTime": { "type": "string", "format": "date-time" },
        "timezone": { "type": "string" },
        "locationType": { "type": "string", "enum": ["Online", "In-Person", "Hybrid"] },
        "locationAddress": { "type": "string" },
        "virtualLink": { "type": "string", "format": "uri" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": [
        "id",
        "name",
        "name_lowercase",
        "creatorId",
        "topic",
        "dateTime",
        "timezone",
        "locationType",
        "attendeeIds",
        "createdAt"
      ]
    },
    "MeetupUpdate": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "title": "MeetupUpdate",
        "type": "object",
        "description": "Represents an update or announcement for a specific meetup.",
        "properties": {
            "id": { "type": "string" },
            "meetupId": { "type": "string" },
            "creatorId": { "type": "string" },
            "content": { "type": "string" },
            "createdAt": { "type": "string", "format": "date-time" }
        },
        "required": ["id", "meetupId", "creatorId", "content", "createdAt"]
    },
    "Task": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Task",
      "type": "object",
      "description": "Represents a task within a study group or project.",
      "properties": {
        "id": { "type": "string" },
        "description": { "type": "string" },
        "isCompleted": { "type": "boolean" },
        "priority": { "type": "string", "enum": ["low", "medium", "high"] },
        "creatorId": { "type": "string" },
        "completedBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "completedAt": { "type": "string", "format": "date-time" },
        "position": { "type": "number", "description": "The order of the task in the list." }
      },
      "required": ["id", "description", "isCompleted", "priority", "creatorId", "createdAt", "position"]
    },
    "CheckIn": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "CheckIn",
      "type": "object",
      "description": "Represents a daily or weekly check-in for a study group or project.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string", "description": "The ID of the user submitting the check-in." },
        "type": { "type": "string", "enum": ["daily", "weekly"] },
        "content": { "type": "string", "description": "The content of the check-in." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "type", "content", "createdAt"]
    },
    "Notification": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Notification",
      "type": "object",
      "description": "Represents a user notification.",
      "properties": {
        "id": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "isRead": {
          "type": "boolean"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "link": {
          "type": "string",
          "format": "uri-reference"
        }
      },
      "required": ["id", "message", "isRead", "createdAt"]
    },
    "Competition": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Competition",
      "type": "object",
      "description": "Represents a coding competition or hackathon.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "name_lowercase": { "type": "string" },
        "description": { "type": "string" },
        "rules": { "type": "string" },
        "prize": { "type": "string" },
        "creatorId": { "type": "string" },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "winnerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "name_lowercase", "description", "creatorId", "startDate", "endDate", "createdAt"]
    },
    "CompetitionEntry": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "CompetitionEntry",
      "type": "object",
      "description": "Represents a user's submission to a competition.",
      "properties": {
        "id": { "type": "string" },
        "competitionId": { "type": "string" },
        "userId": { "type": "string" },
        "username": { "type": "string" },
        "projectUrl": { "type": "string", "format": "uri" },
        "soloProjectId": { "type": "string" },
        "description": { "type": "string" },
        "submittedAt": { "type": "string", "format": "date-time" },
        "voterIds": {
          "type": "array",
          "description": "A list of user IDs who have voted for this entry.",
          "items": { "type": "string" }
        }
      },
      "required": ["id", "competitionId", "userId", "username", "projectUrl", "submittedAt"]
    },
    "Feedback": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Feedback",
      "type": "object",
      "description": "Represents user-submitted feedback for the site.",
      "properties": {
        "id": {
          "type": "string"
        },
        "feedback": {
          "type": "string",
          "description": "The main content of the feedback submission."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the feedback was submitted."
        },
        "userId": {
          "type": "string",
          "description": "The ID of the user who submitted the feedback (if logged in)."
        },
        "username": {
            "type": "string",
            "description": "The username of the user who submitted the feedback (if logged in)."
        }
      },
      "required": ["id", "feedback", "createdAt"]
    },
    "SupportRequest": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "title": "SupportRequest",
        "type": "object",
        "description": "Represents a user-submitted support request.",
        "properties": {
            "id": { "type": "string" },
            "userId": { "type": "string" },
            "username": { "type": "string" },
            "email": { "type": "string", "format": "email" },
            "subject": { "type": "string" },
            "description": { "type": "string" },
            "status": { "type": "string", "enum": ["open", "in_progress", "closed"] },
            "createdAt": { "type": "string", "format": "date-time" }
        },
        "required": ["id", "userId", "username", "email", "subject", "description", "status", "createdAt"]
    },
    "SoloProject": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "SoloProject",
      "type": "object",
      "description": "Represents a user's individual project.",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the SoloProject." },
        "userId": { "type": "string", "description": "The ID of the user who created the project." },
        "username": { "type": "string", "description": "The username of the user who created the project." },
        "name": { "type": "string", "description": "The name of the project." },
        "projectUrl": { "type": "string", "format": "uri", "description": "URL to the live project or repository." },
        "description": { "type": "string", "description": "A description of the project." },
        "createdAt": { "type": "string", "format": "date-time", "description": "The timestamp when the project was submitted." }
      },
      "required": ["id", "userId", "username", "name", "projectUrl", "createdAt"]
    },
    "MentorshipRequest": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "MentorshipRequest",
      "type": "object",
      "description": "Represents a request for mentorship between two users.",
      "properties": {
        "id": {
          "type": "string"
        },
        "fromUid": {
          "type": "string"
        },
        "toUid": {
          "type": "string"
        },
        "fromUsername": {
          "type": "string"
        },
        "toUsername": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": [
            "seeking_mentor",
            "seeking_mentee"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "pending",
            "accepted",
            "declined"
          ]
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "fromUid",
        "toUid",
        "fromUsername",
        "toUsername",
        "type",
        "status",
        "createdAt"
      ]
    },
    "Mentorship": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Mentorship",
      "type": "object",
      "description": "Represents a mentorship relationship between two users.",
      "properties": {
        "id": { "type": "string" },
        "memberIds": { "type": "array", "items": { "type": "string" } },
        "mentorId": { "type": "string" },
        "menteeId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "memberIds", "mentorId", "menteeId", "createdAt"]
    },
    "TutorRequest": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "TutorRequest",
      "type": "object",
      "description": "Represents a request for tutoring between two users.",
      "properties": {
        "id": {
          "type": "string"
        },
        "fromUid": {
          "type": "string"
        },
        "toUid": {
          "type": "string"
        },
        "fromUsername": {
          "type": "string"
        },
        "toUsername": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": [
            "seeking_tutor",
